# ─── Lock files ────────────────────────────────────────────────────────────
*.lock
watchdog_*.lock

# ─── Bot runtime output (trade history, balances, positions, PnL) ──────────
output/
output/**
.backfill_cursor

# ─── Bulk snapshots / archived state ───────────────────────────────────────
# Note: can't use !cowork_snapshot/X exception under an ignored parent dir, so
# we ignore the contents instead of the dir itself. Anything tracked is kept
# (git ignore only affects untracked files).
cowork_snapshot/bot/
cowork_snapshot/5m_live/
cowork_snapshot/5m_trading/
cowork_snapshot/esports/scrape/
cowork_snapshot/esports/*.parquet
cowork_snapshot/esports/*_results.json
cowork_snapshot/esports/clob_token_to_market.json
cowork_snapshot/esports/token_to_market.json
cowork_snapshot/*.log
cowork_snapshot/*.zip
cowork_snapshot/*.md
cowork_snapshot/main.py
bot_data_snapshot.zip
*.zip.*
data.zip*

# fade_targets.json + follow_targets.json INTENTIONALLY kept tracked so the
# bot has wallet lists on fresh clones / new machines.

