POLYGON_RPC=
POLYMARKET_START_BLOCK=33605403

# ── Live Trading ──────────────────────────────────────────────────────────────
# Set LIVE_TRADING=true to place real orders on Polymarket.
# Leave as false (default) to run in paper/simulation mode only.
#
# POLYMARKET_PRIVATE_KEY: your Polygon wallet private key (starts with 0x).
#   This wallet must hold USDC on the Polygon network as trading collateral.
#   Keep this value secret — never share it or commit it to git.
#
# How to get started:
#   1. Create a Polygon wallet (e.g. MetaMask) and export the private key.
#   2. Bridge USDC to Polygon (e.g. via Polygon Bridge or a centralised exchange).
#   3. Go to polymarket.com, connect your wallet, and approve the USDC allowance.
#   4. Paste your private key below and set LIVE_TRADING=true.
LIVE_TRADING=false
POLYMARKET_PRIVATE_KEY=
